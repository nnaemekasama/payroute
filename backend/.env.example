# Copy this file to .env and fill in the values.
# Required for local development. Never commit .env.

# PostgreSQL connection string (replace with your user/password/host)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/payroute

# Webhook HMAC secret (generate a random string for production)
WEBHOOK_SECRET=your_webhook_secret_replace_me

# Optional
# PORT=3000
# FX_QUOTE_TTL_SECONDS=300
