# Copy this file to .env and fill in the values.
# Required for local development.

# PostgreSQL connection string (use same user/password as your Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payroute

# Webhook HMAC secret (use any string for local dev)
WEBHOOK_SECRET=whsec_test_secret_key_for_hmac

# Server port (optional, defaults to 3000)
PORT=3000

# FX quote TTL in seconds (optional, defaults to 300)
# FX_QUOTE_TTL_SECONDS=300
